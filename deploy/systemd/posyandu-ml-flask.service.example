[Unit]
Description=Posyandu ML Flask Prediction API
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/posyandu-ml-backend/ml-api
Environment="PORT=5000"
Environment="MODEL_VERSION=random_forest_v1"
ExecStart=/var/www/posyandu-ml-backend/ml-api/.venv/bin/gunicorn --workers 1 --bind 127.0.0.1:5000 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
